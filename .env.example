# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# RAWG API Configuration (Games Data)
EXPO_PUBLIC_RAWG_API_KEY=your_rawg_api_key

# IGDB API Configuration (Twitch Developer Portal)
EXPO_PUBLIC_IGDB_CLIENT_ID=your_twitch_client_id
EXPO_PUBLIC_IGDB_ACCESS_TOKEN=your_twitch_app_access_token

# TMDB API Configuration (Movies/TV Data)
EXPO_PUBLIC_TMDB_API_KEY=your_tmdb_api_key
