EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
EXPO_PUBLIC_RAWG_API_KEY=your_rawg_api_key_here

# IGDB now runs through Supabase Edge Function `igdb-proxy`.
# Do NOT put IGDB client ID/access token in Expo public env vars.
# Set server-side secrets in Supabase instead:
#   IGDB_TWITCH_CLIENT_ID
#   IGDB_TWITCH_CLIENT_SECRET
