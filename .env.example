EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
EXPO_PUBLIC_RAWG_API_KEY=your_rawg_api_key_here

# IGDB (Twitch) — used for rich game details in details_games.jsx
# Setup: https://dev.twitch.tv/console/apps
# Get token: curl -X POST "https://id.twitch.tv/oauth2/token" -d "client_id=X&client_secret=Y&grant_type=client_credentials"
EXPO_PUBLIC_IGDB_CLIENT_ID=your_twitch_client_id_here
EXPO_PUBLIC_IGDB_ACCESS_TOKEN=your_igdb_access_token_here
